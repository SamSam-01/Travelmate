{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Flutter",
            "request": "launch",
            "type": "dart",
            "args": ["--dart-define-from-file=.env"]
        },
        {
            "name": "Simulator",
            "request": "launch",
            "type": "dart",
            "program": "lib/main.dart",
            "cwd": "front",
            "args": ["--dart-define-from-file=.env"]
        },
        {
            "name": "front",
            "cwd": "front",
            "request": "launch",
            "type": "dart",
            "args": ["--dart-define-from-file=.env"]
        },
        {
            "name": "front (profile mode)",
            "cwd": "front",
            "request": "launch",
            "type": "dart",
            "flutterMode": "profile",
            "args": ["--dart-define-from-file=.env"]
        },
        {
            "name": "front (release mode)",
            "cwd": "front",
            "request": "launch",
            "type": "dart",
            "flutterMode": "release",
            "args": ["--dart-define-from-file=.env"]
        }
    ]
}